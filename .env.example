# ==============================================================================
# MERSİN TARIM ASİSTANI - ÇEVRESEL DEĞİŞKENLER (ENVIRONMENT VARIABLES)
# ==============================================================================

# 1. YAPAY ZEKA VE PAZARLAMA ENTEGRASYONLARI
# ------------------------------------------------------------------------------
# Gemini API Anahtarı: Sistemdeki yaprak/hastalık teşhisi, akıllı envanter dozaj
# hesaplamaları ve genel tarım asistanı tavsiyeleri için zorunludur.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# 2. UYGULAMA ERİŞİM BİLGİLERİ
# ------------------------------------------------------------------------------
# Uygulama URL'si: Bulut dağıtımı sırasında self-referential yönlendirmeler ve
# QR kod köprüleri oluşturmak için sistem tarafından otomatik atanır.
APP_URL=http://localhost:3001
PORT=3001
NODE_ENV="development"

# 3. VERİTABANI VE YEDEKLME AYARLARI
# ------------------------------------------------------------------------------
# Veritabanı Tipi: local_json veya sqlite (SQLite desteği için yerel kütüphaneler kullanılır)
DATABASE_TYPE="local_json"
DATABASE_PATH="./data/tarim_hafizasi.json"
BACKUP_DIR="./backups"
BACKUP_INTERVAL_HOURS=24

# 4. BÖLGESEL COĞRAFİ AYARLAR (Mersin, Toroslar, Değirmençay)
# ------------------------------------------------------------------------------
DEFAULT_LATITUDE=36.8741
DEFAULT_LONGITUDE=34.4512
DEFAULT_LOCATION_NAME="Toroslar, Değirmençay, Mersin"

# 5. GÜVENLİK AYARLARI
# ------------------------------------------------------------------------------
SESSION_SECRET="tarim_asistani_secure_session_token_2026"
ADMIN_DEFAULT_PASSWORD="admin_degirmencay_33"
