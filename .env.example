# ==========================================================================
# Mersin AgriTech - Ortam Değişkenleri Örneği
# Bu dosyayı ".env" olarak kopyalayıp kendi değerlerinizle doldurun.
# ==========================================================================

# --- Genel ---
NODE_ENV=development
PORT=3000

# --- Veritabanı ---
# Boş bırakılırsa varsayılan olarak <proje-kökü>/data/tarim_hafizasi.json kullanılır.
DATABASE_TYPE=local_json
DATABASE_PATH=

# Bundled Mersin Değirmençay örnek/demo verisinin (parsel, gider, satış vb.)
# boş bir veritabanında otomatik oluşturulup oluşturulmayacağını belirler.
# Üretim/gerçek kullanım için "false" kalmalıdır.
SEED_SAMPLE_DATA=false

# --- Fotoğraf Depolama ---
# Boş bırakılırsa varsayılan olarak <proje-kökü>/data/photos kullanılır.
PHOTOS_STORAGE_DIR=

# --- Otomatik Yedekleme ---
# Boş bırakılırsa varsayılan olarak <proje-kökü>/backups kullanılır.
BACKUP_DIR=
# Kaç saatte bir otomatik yedek alınacağı.
BACKUP_INTERVAL_HOURS=24
# En fazla kaç adet zaman damgalı yedek dosyasının saklanacağı
# (bu sayının üzerindeki en eski yedekler otomatik silinir).
BACKUP_MAX_SNAPSHOTS=30
# (İsteğe bağlı) Google Drive for Desktop uygulamasının bilgisayarınızda
# oluşturduğu senkronize klasörün TAM yolu. Ayarlanırsa, her yedek bu
# klasöre de kopyalanır ve Google Drive otomatik olarak buluta yükler.
# Google API anahtarı GEREKMEZ. Örnek (Windows):
# GOOGLE_DRIVE_BACKUP_PATH=G:\Drive'ım\MersinAgriTechYedekleri
GOOGLE_DRIVE_BACKUP_PATH=

# --- Coğrafi Varsayılanlar (Mersin Toroslar / Değirmençay) ---
DEFAULT_LATITUDE=36.8741
DEFAULT_LONGITUDE=34.4512
DEFAULT_LOCATION_NAME=Toroslar, Değirmençay, Mersin

# --- Güvenlik ---
# Oturum belirteçlerini imzalamak için kullanılan gizli anahtar.
# Üretimde MUTLAKA benzersiz, rastgele bir değerle değiştirin.
SESSION_SECRET=
# Sistem ilk kurulduğunda varsayılan admin kullanıcısına atanacak şifre.
# Kuruluşdan hemen sonra değiştirilmesi şiddetle önerilir.
ADMIN_DEFAULT_PASSWORD=

# --- Yapay Zeka (Google Gemini) ---
GEMINI_API_KEY=
